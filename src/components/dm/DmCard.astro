---
export interface Props {
  class?: string;
  padding?: "none" | "sm" | "md" | "lg";
  dataTestid?: string;
}

const { class: className = "", padding = "md", dataTestid } = Astro.props;

const paddingClasses: Record<string, string> = {
  none: "",
  sm: "p-4",
  md: "p-5",
  lg: "p-6",
};

const baseClasses =
  "rounded-xl bg-[var(--bg-card)] border border-[var(--border-gold-strong)] shadow-lg shadow-black/20 hover:border-[var(--border-gold)] transition-all duration-[var(--transition-base)]";

const classes = `${baseClasses} ${paddingClasses[padding]} ${className}`;
---

<div class={classes} data-testid={dataTestid}>
  <slot />
</div>
