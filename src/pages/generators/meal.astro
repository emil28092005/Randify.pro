---
import GeneratorLayout from "@/layouts/GeneratorLayout.astro";
import MealGenerator from "@/components/generators/MealGenerator.astro";
import { generators } from "@/data/generators";

const generator = generators.find((g) => g.slug === "meal")!;
---
export const prerender = true;

<GeneratorLayout generator={generator}>
  <MealGenerator />
</GeneratorLayout>
