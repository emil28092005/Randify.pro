---
import DmCard from "./DmCard.astro";
import DmInput from "./DmInput.astro";
import DmButton from "./DmButton.astro";
import { dmTranslations as T } from "@/i18n/dm-translations";

const quickDice = [
  { label: "d4", notation: "d4" },
  { label: "d6", notation: "d6" },
  { label: "d8", notation: "d8" },
  { label: "d10", notation: "d10" },
  { label: "d12", notation: "d12" },
  { label: "d20", notation: "d20" },
  { label: "d100", notation: "d100" },
];
---

<div data-testid="dice-section">
<DmCard>
  <div class="space-y-5">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-semibold text-[var(--text-primary)]">
        {T.dice}
      </h3>
    </div>

    <div
      class="grid grid-cols-4 sm:grid-cols-7 gap-2"
      id="quick-dice-grid"
      role="group"
      aria-label="Quick dice selectors"
    >
      {
        quickDice.map((d) => (
          <button
            type="button"
            data-notation={d.notation}
            data-dice={d.label}
            class="quick-dice-btn rounded-full border border-[var(--gold)] bg-[var(--bg-secondary)] px-2 py-2 text-sm font-semibold text-[var(--gold)] transition-all duration-[var(--transition-base)] hover:bg-[var(--gold)]/10 hover:shadow-lg hover:shadow-[var(--gold)]/20 active:scale-[0.97] active:bg-[var(--accent)] active:text-white active:border-[var(--accent)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg-primary)]"
          >
            {d.label}
          </button>
        ))
      }
    </div>

    <div class="flex gap-2 items-end">
      <DmInput
        id="dice-notation"
        name="notation"
        placeholder="e.g. 2d6+3"
        label={T.customFormula}
        class="flex-1"
        dataTestid="dice-input"
      />
      <DmButton variant="primary" size="md" class="roll-btn" dataTestid="dice-roll-btn">
        {T.actionRoll}
      </DmButton>
    </div>

    <div
      id="result-display"
      class="hidden rounded-xl bg-[var(--bg-secondary)] border border-[var(--border-color)] p-5 text-center"
      aria-live="polite"
    >
      <div class="text-sm text-[var(--text-secondary)] mb-1" id="result-label">
        Result
      </div>
      <div
        class="text-5xl font-bold text-[var(--gold)]"
        id="result-total"
        data-testid="dice-result"
      >
        0
      </div>
      <div
        class="text-sm text-[var(--text-secondary)] mt-1"
        id="result-details"
      >
      </div>
      <div
        class="text-sm font-semibold mt-1 hidden"
        id="result-crit-message"
      >
      </div>
    </div>

    <div id="history-section">
      <div class="flex items-center justify-between mb-2">
        <h4 class="text-sm font-medium text-[var(--text-secondary)]">
          {T.rollHistory}
        </h4>
        <DmButton variant="secondary" size="sm" class="clear-history-btn" dataTestid="dice-clear-btn">
          {T.actionClear}
        </DmButton>
      </div>

      <div
        id="history-empty"
        data-testid="dice-empty-state"
        class="flex flex-col items-center justify-center py-6 text-[var(--text-muted)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mb-2 opacity-40"
        >
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
          <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none" />
          <circle cx="7" cy="7" r="1" fill="currentColor" stroke="none" />
          <circle cx="17" cy="7" r="1" fill="currentColor" stroke="none" />
          <circle cx="7" cy="17" r="1" fill="currentColor" stroke="none" />
          <circle cx="17" cy="17" r="1" fill="currentColor" stroke="none" />
        </svg>
        <span class="text-sm">{T.emptyDiceHistory}</span>
      </div>

      <ul
        id="history-list"
        class="space-y-1 max-h-40 overflow-y-auto hidden"
        role="list"
        aria-label="Roll history"
      >
      </ul>
    </div>
  </div>
</DmCard>
</div>

<script>
  import { parseDiceNotation, rollDice } from "@/lib/client/dice";
  import { popElement } from "@/lib/client/animations";
  import { dmTranslations as T } from "@/i18n/dm-translations";

  const STORAGE_KEY = "dm-dice-history";
  const MAX_HISTORY = 10;

  interface HistoryEntry {
    notation: string;
    total: number;
    rolls: number[];
    modifier: number;
    timestamp: number;
    status?: "crit" | "fail" | "normal";
  }

  function loadHistory(): HistoryEntry[] {
    try {
      let raw = sessionStorage.getItem(STORAGE_KEY);
      let migratedFromOld = false;

      // Fallback: migrate from old storage key
      if (!raw) {
        const oldRaw = sessionStorage.getItem("dice-roller-history");
        if (oldRaw) {
          raw = oldRaw;
          migratedFromOld = true;
        }
      }

      if (!raw) return [];
      const parsed = JSON.parse(raw) as Array<{
        result?: number;
        total?: number;
        rolls?: unknown[];
        formula?: string;
        notation?: string;
        modifier?: number;
        status?: "crit" | "fail" | "normal";
        isCrit?: boolean;
        isFail?: boolean;
      }>;

      // Migrate old-format entries
      const migrated = parsed.map((entry) => {
        if (entry.result !== undefined && entry.total === undefined) {
          entry.total = entry.result;
        }
        if (!entry.rolls || !Array.isArray(entry.rolls)) {
          entry.rolls = [];
        }
        if (entry.formula !== undefined && entry.notation === undefined) {
          entry.notation = entry.formula;
        }
        if (entry.modifier === undefined) {
          entry.modifier = 0;
        }
        if (entry.status === undefined && (entry.isCrit || entry.isFail)) {
          entry.status = entry.isCrit ? "crit" : "fail";
        }
        return entry as HistoryEntry;
      });

      // Save migrated data back to prevent repeated migration
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(migrated));

      // Remove old key if we migrated from it
      if (migratedFromOld) {
        sessionStorage.removeItem("dice-roller-history");
      }

      return migrated;
    } catch {
      return [];
    }
  }

  function saveHistory(history: HistoryEntry[]) {
    try {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(history));
    } catch {
      // sessionStorage may be unavailable
    }
  }

  function getRollStatus(
    rolls: number[],
    sides: number,
  ): "crit" | "fail" | "normal" {
    if (sides !== 20) return "normal";
    if (rolls.includes(20)) return "crit";
    if (rolls.includes(1)) return "fail";
    return "normal";
  }

  function getSidesFromNotation(notation: string): number | null {
    const match = notation.trim().toLowerCase().match(/^(\d*)\s*d\s*(\d+)/);
    return match ? parseInt(match[2], 10) : null;
  }

  function getHistoryEntryStatus(
    entry: HistoryEntry,
  ): "crit" | "fail" | "normal" {
    if (entry.status) return entry.status;
    const sides = getSidesFromNotation(entry.notation);
    if (!sides || sides !== 20) return "normal";
    if (!entry.rolls || entry.rolls.length === 0) return "normal";
    if (entry.rolls.includes(20)) return "crit";
    if (entry.rolls.includes(1)) return "fail";
    return "normal";
  }

  function addToHistory(entry: HistoryEntry) {
    const history = loadHistory();
    history.unshift(entry);
    if (history.length > MAX_HISTORY) {
      history.length = MAX_HISTORY;
    }
    saveHistory(history);
    renderHistory();
  }

  function clearHistory() {
    saveHistory([]);
    renderHistory();
  }

  function renderHistory() {
    const history = loadHistory();
    const empty = document.getElementById("history-empty");
    const list = document.getElementById("history-list");
    if (!empty || !list) return;

    if (history.length === 0) {
      empty.classList.remove("hidden");
      list.classList.add("hidden");
      list.innerHTML = "";
      return;
    }

    empty.classList.add("hidden");
    list.classList.remove("hidden");
    list.innerHTML = history
      .map((entry) => {
        const status = getHistoryEntryStatus(entry);
        const totalClass =
          status === "crit"
            ? "text-[#6ab04c]"
            : status === "fail"
              ? "text-[#e06060]"
              : "text-[var(--gold)]";
        return `
          <li data-testid="dice-history-item" class="flex items-center justify-between rounded-md bg-[var(--bg-secondary)] px-3 py-2 text-sm">
            <span class="text-[var(--text-secondary)]">${entry.notation}</span>
            <span class="font-semibold ${totalClass}">${entry.total}</span>
          </li>
        `;
      })
      .join("");
  }

  function showResult(
    notation: string,
    result: { rolls: number[]; total: number; modifier: number },
    status: "crit" | "fail" | "normal",
  ) {
    const display = document.getElementById("result-display");
    const totalEl = document.getElementById("result-total");
    const detailsEl = document.getElementById("result-details");
    const labelEl = document.getElementById("result-label");
    const critMsg = document.getElementById("result-crit-message");
    if (!display || !totalEl || !detailsEl || !labelEl) return;

    display.classList.remove("hidden");
    totalEl.textContent = String(result.total);
    labelEl.textContent = notation;

    const rolls = result.rolls.join(", ");
    if (result.modifier !== 0) {
      const sign = result.modifier > 0 ? "+" : "";
      detailsEl.textContent = `Rolls: ${rolls} ${sign}${result.modifier}`;
    } else {
      detailsEl.textContent = `Rolls: ${rolls}`;
    }

    totalEl.className = `text-5xl font-bold ${
      status === "crit"
        ? "text-[#6ab04c]"
        : status === "fail"
          ? "text-[#e06060]"
          : "text-[var(--gold)]"
    }`;

    if (critMsg) {
      if (status === "crit") {
        critMsg.textContent = T.criticalHit;
        critMsg.className = "text-sm font-semibold mt-1 text-[#6ab04c]";
      } else if (status === "fail") {
        critMsg.textContent = T.criticalFail;
        critMsg.className = "text-sm font-semibold mt-1 text-[#e06060]";
      } else {
        critMsg.className = "text-sm font-semibold mt-1 hidden";
      }
    }

    popElement(totalEl);

    addToHistory({
      notation,
      total: result.total,
      rolls: result.rolls,
      modifier: result.modifier,
      timestamp: Date.now(),
      status,
    });
  }

  function performRoll(notation: string) {
    const trimmed = notation.trim();
    if (!trimmed) return;

    try {
      const parsed = parseDiceNotation(trimmed);
      const result = rollDice(parsed.count, parsed.sides, parsed.modifier);
      const status = getRollStatus(result.rolls, parsed.sides);
      showResult(trimmed, result, status);
    } catch {
      const display = document.getElementById("result-display");
      const totalEl = document.getElementById("result-total");
      const detailsEl = document.getElementById("result-details");
      const labelEl = document.getElementById("result-label");
      const critMsg = document.getElementById("result-crit-message");
      if (!display || !totalEl || !detailsEl || !labelEl) return;

      display.classList.remove("hidden");
      totalEl.textContent = "?";
      totalEl.className = "text-5xl font-bold text-[var(--gold)]";
      labelEl.textContent = trimmed;
      detailsEl.textContent = "Invalid notation";
      if (critMsg) {
        critMsg.className = "text-sm font-semibold mt-1 hidden";
      }
    }
  }

  const quickButtons = document.querySelectorAll<HTMLButtonElement>(
    ".quick-dice-btn",
  );
  quickButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const notation = btn.dataset.notation;
      if (notation) {
        const input = document.getElementById(
          "dice-notation",
        ) as HTMLInputElement | null;
        if (input) input.value = notation;
        performRoll(notation);
      }
    });
  });

  const rollBtn = document.querySelector(".roll-btn");
  rollBtn?.addEventListener("click", () => {
    const input = document.getElementById(
      "dice-notation",
    ) as HTMLInputElement | null;
    performRoll(input?.value ?? "");
  });

  const notationInput = document.getElementById(
    "dice-notation",
  ) as HTMLInputElement | null;
  notationInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      performRoll(notationInput.value);
    }
  });

  const clearBtn = document.querySelector(".clear-history-btn");
  clearBtn?.addEventListener("click", clearHistory);

  renderHistory();
</script>
